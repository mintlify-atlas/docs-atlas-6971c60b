  "keyFeatures": [
    "161+ algorithm implementations covering graphs, strings, math, and data structures",
    "Automatic snippet generation for VS Code and Vim/Neovim",
    "Optimized templates for competitive programming contests (USACO, Google Code Jam, LeetCode)",
    "Comprehensive debugging utilities and macros",
    "Advanced data structures including segment trees with lazy propagation, tries, and DSU",
    "String algorithms: KMP, Rabin-Karp, Aho-Corasick, Manacher, suffix arrays",
    "Graph algorithms: Dijkstra, Bellman-Ford, Floyd-Warshall, Kruskal, topological sort",
    "Range query structures: Segment Tree, Fenwick Tree, Sparse Table, Square Root Decomposition"
  ],
  "publicApiSurface": [
    "dijkstra<T>(graph, start) - Shortest path from source",
    "bellman_ford<T>(graph, start) - Shortest path with negative weights",
    "floyd_warshall<T>(graph) - All-pairs shortest paths",
    "kruskal<T>(edges, n) - Minimum spanning tree",
    "DSU - Disjoint Set Union data structure",
    "SegmentTree - Range query data structure",
    "FenwickTree - Binary indexed tree",
    "Trie - Prefix tree for string operations",
    "KMP(pattern, text) - Pattern matching",
    "RabinKarp(pattern, text) - Rolling hash pattern matching",
    "AhoCorasick - Multi-pattern matching automaton",
    "SuffixArray(string) - Suffix array construction",
    "Mint<MOD> - Modular arithmetic template",
    "BigInt - Arbitrary precision integers",
    "Matrix<T> - Matrix operations",
    "BinaryLifting - LCA queries on trees",
    "SparseTable<T> - Static RMQ in O(1)",
    "CoordinateCompression - Compress coordinate values",
    "Y-Combinator - Recursive lambda pattern"
  ]
}
